server {
    listen 80;
    server_name unlimited-clipboard.cetle.cn;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name unlimited-clipboard.cetle.cn;

    # Replace with the paths managed by your existing certificate provider.
    ssl_certificate /etc/letsencrypt/live/unlimited-clipboard.cetle.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/unlimited-clipboard.cetle.cn/privkey.pem;

    client_max_body_size 32m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
